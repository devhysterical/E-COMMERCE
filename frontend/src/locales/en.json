    "items": [
      {
        "question": "How do I place an order?",
        "answer": "Browse products, add items to your cart, and proceed to checkout. Choose your preferred payment method, enter your shipping address, and confirm the order."
      },
      {
        "question": "How long does shipping take?",
        "answer": "Delivery time depends on your area. Ho Chi Minh City usually takes 1-2 days, nearby southern provinces 2-3 days, and central or northern regions 3-5 days."
      },
      {
        "question": "What is your return policy?",
        "answer": "We accept returns within 7 days of delivery. Products must be unused, still sealed, and accompanied by the purchase invoice."
      },
      {
        "question": "Which payment methods are supported?",
        "answer": "We currently support cash on delivery (COD) and the MoMo e-wallet."
      },
      {
        "question": "How does the loyalty program work?",
        "answer": "Each successful order earns reward points. You can redeem points for discount coupons or free shipping, and higher membership tiers earn more points per order."
      },
      {
        "question": "How can I contact support?",
        "answer": "You can submit a support request through the Contact page and our team will reply within 24 business hours."
      }
    ]
  },
